ActiveThorns = "
    CarpetX
    IOUtil
    CoordinatesX
    CapyrX_MultiPatch
    CapyrX_TestMultiPatch
"
 
Cactus::presync_mode = "mixed-error"
Cactus::cctk_show_schedule = yes

Cactus::terminate = "iteration"
Cactus::cctk_itlast = 0

CarpetX::verbose = yes
CarpetX::poison_undefined_values = yes

CarpetX::blocking_factor_x = 1
CarpetX::blocking_factor_y = 1
CarpetX::blocking_factor_z = 1

CarpetX::max_num_levels = 1

CarpetX::ghost_size          = 2
CarpetX::interpolation_order = 1

CapyrX_MultiPatch::verbose        =  yes
CapyrX_MultiPatch::patch_system   = "TwoCubes"
CapyrX_MultiPatch::run_unit_tests = yes
CapyrX_MultiPatch::patch_overlap  = 0

CapyrX_MultiPatch::cartesian_xmin = -1.0
CapyrX_MultiPatch::cartesian_xmax = +1.0

CapyrX_MultiPatch::cartesian_ymin = -1.0
CapyrX_MultiPatch::cartesian_ymax = +1.0

CapyrX_MultiPatch::cartesian_zmin = -1.0
CapyrX_MultiPatch::cartesian_zmax = +1.0

CapyrX_MultiPatch::cartesian_ncells_i = 5
CapyrX_MultiPatch::cartesian_ncells_j = 10
CapyrX_MultiPatch::cartesian_ncells_k = 10

CapyrX_MultiPatch::two_cubes_bend = 0.0
                                                                        
CapyrX_TestMultiPatch::test_data = "standing wave"

CarpetX::boundary_x       = "dirichlet"
CarpetX::boundary_y       = "dirichlet"
CarpetX::boundary_z       = "dirichlet"
CarpetX::boundary_upper_x = "dirichlet"
CarpetX::boundary_upper_y = "dirichlet"
CarpetX::boundary_upper_z = "dirichlet"

IO::out_dir = $parfile
IO::out_every = 1

CarpetX::out_performance = no
CarpetX::out_metadata = no

CarpetX::out_tsv = no
CarpetX::out_tsv_vars = "
  CoordinatesX::vertex_coords
  CapyrX_TestMultiPatch::test_data
  CapyrX_TestMultiPatch::error
"
