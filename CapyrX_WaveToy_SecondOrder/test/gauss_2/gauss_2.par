# Gaussian
# No mesh refinement
# No dissipation
# With NewRadX boundaries
# Overlap

ActiveThorns = "
    CapyrX_MultiPatch
    CapyrX_WaveToy_SecondOrder
    CarpetX
    CoordinatesX
    IOUtil
    ODESolvers
"

# Misc options
Cactus::presync_mode = "mixed-error"
Cactus::cctk_show_schedule = yes

CarpetX::verbose = yes
CarpetX::poison_undefined_values = yes

# Block distribution
CarpetX::blocking_factor_x = 1
CarpetX::blocking_factor_y = 1
CarpetX::blocking_factor_z = 1

# Time integration
ODESolvers::method  = "RK4"
ODESolvers::verbose = yes
CarpetX::dtfac      = 0.25

# Grid
CapyrX_MultiPatch::verbose        =  yes
CapyrX_MultiPatch::patch_system   = "Cubed sphere"

CapyrX_MultiPatch::inner_boundary_radius = 2.0
CapyrX_MultiPatch::outer_boundary_radius = 8.0
CapyrX_MultiPatch::angular_cells         = 40
CapyrX_MultiPatch::radial_cells          = 60

CarpetX::ghost_size               = 3
CarpetX::interpolation_order      = 4
CapyrX_MultiPatch::patch_overlap  = 5

# Dissipation and NewRadX
CapyrX_WaveToy_SecondOrder::add_dissipation = yes
CapyrX_WaveToy_SecondOrder::use_newradx     = yes

# Initial data
CapyrX_WaveToy_SecondOrder::initial_condition = "Gaussian"
CapyrX_WaveToy_SecondOrder::amplitude         = 1.0
CapyrX_WaveToy_SecondOrder::gaussian_width    = 1.0 / 2.0

# Boundary conditions
CarpetX::boundary_x       = "linear extrapolation"
CarpetX::boundary_y       = "linear extrapolation"
CarpetX::boundary_z       = "linear extrapolation"
CarpetX::boundary_upper_x = "linear extrapolation"
CarpetX::boundary_upper_y = "linear extrapolation"
CarpetX::boundary_upper_z = "linear extrapolation"

# Termination
Cactus::terminate   = "iteration"
Cactus::cctk_itlast = 64

# Output
IO::out_dir = $parfile
IO::out_every = 16

CarpetX::out_metadata    = no
CarpetX::out_performance = no

CarpetX::out_tsv_vars = "
    CapyrX_WaveToy_SecondOrder::state
    CapyrX_WaveToy_SecondOrder::energy
"
